{
  "plugins": [
    "plugins/markdown",
    "better-docs/typescript",
    "jsdoc-plugin-typescript"
  ],
  "recurseDepth": 10,
  "source": {
    "include": [
      "src"
    ],
    "exclude": [
      "src/tree.ts"
    ],
    "includePattern": ".ts$",
    "excludePattern": "(node_modules|build|dist|docs)"
  },
  "opts": {
    "destination": "./docs",
    "template": "node_modules/better-docs",
    "encoding": "utf8",
    "recurse": true,
    "readme": "./README.md"
  }
}