{
  "name": "jstreemap",
  "type": "module",
  "version": "2.3.0",
  "description": "Library of associative containers; it implements TreeMap, TreeSet, TreeMultiMap and TreeMultiSet classes",
  "main": "./dist/umd/jstreemap.js",
  "types": "./dist/esm/jstreemap.d.ts",
  "module": "./dist/esm/jstreemap.js",
  "unpkg": "./dist/umd/jstreemap.js",
  "exports": {
    ".": {
      "import": "./dist/esm/jstreemap.js",
      "types": "./dist/esm/jstreemap.d.ts",
      "require": "./dist/umd/jstreemap.js",
      "default": "./dist/umd/jstreemap.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "analyze-tests": "tsx ./tools/analyze-tests.ts dev-tests.json",
    "compile": "tsc",
    "dev-test": "vitest run -c vitest.config.ts run test/specs/*.test.ts",
    "eslint": "eslint --config=./eslint.config.js",
    "eslint-fix": "eslint --config=./eslint.config.js --fix",
    "generate-tests": "tsx ./tools/generate-tests.ts ../build/compiled/test/specs ../build/generated-tests",
    "jsdoc": "jsdoc -c ./config/jsdoc.json",
    "preprod-esm-tests": "vitest run -c vitest.config.preprod.ts run build/generated-tests/esm-tests/*.test.js",
    "preprod-umd-tests": "vitest run -c vitest.config.preprod.ts run build/generated-tests/umd-tests/*.test.js",
    "web-test": "vitest -c vitest.config.preprod.ts run test/browser/*.test.ts",
    "webpack": "webpack --config ./config/webpack.config.js"
  },
  "directories": {
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirusi/jstreemap.git"
  },
  "keywords": [
    "set",
    "map",
    "multimap",
    "multiset",
    "red",
    "black",
    "tree",
    "stl",
    "iterator",
    "multimap",
    "treemap",
    "multiset",
    "treeset",
    "lower_bound",
    "lowerBound",
    "upper_bound",
    "upperBound",
    "ordered",
    "container",
    "find",
    "insert",
    "delete",
    "erase",
    "template",
    "library",
    "dictionary",
    "key",
    "value"
  ],
  "author": "Kirusi Msafiri",
  "license": "0BSD",
  "bugs": {
    "url": "https://github.com/kirusi/jstreemap/issues"
  },
  "homepage": "https://github.com/kirusi/jstreemap#readme",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/should": "^11.2.0",
    "@vitest/coverage-istanbul": "^4.1.9",
    "better-docs": "^2.7.3",
    "cross-env": "^10.1.0",
    "del": "^8.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.7",
    "eslint-plugin-prettier": "^5.5.6",
    "gh-badges": "^2.2.2",
    "gulp": "^5.0.1",
    "jsdoc": "^4.0.5",
    "jsdoc-plugin-typescript": "^3.2.1",
    "lighthouse-badges": "^1.5.4",
    "mocha": "^11.7.6",
    "npm-dts-webpack-plugin": "^1.3.13",
    "nyc": "^18.0.0",
    "plugin-error": "^1.0.1",
    "selenium-webdriver": "^4.44.0",
    "should": "^13.2.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  }
}